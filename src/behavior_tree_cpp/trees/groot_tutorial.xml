<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence>
      <CalculateGoal goal="{key_1}"/>
      <Script code="key_2:=&apos;2;5&apos;"/>
      <PrintTarget target="{key_1}"/>
      <PrintTarget target="{key_2}"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="CalculateGoal">
      <output_port name="goal"
                   type="Position2D"/>
    </Action>
    <Action ID="PrintTarget">
      <input_port name="target"
                  type="Position2D">Simply print the goal on console...</input_port>
    </Action>
  </TreeNodesModel>

</root>
