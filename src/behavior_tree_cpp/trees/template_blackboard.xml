<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="maintree">
    <Sequence>
      <SetTemplateBlackboard points="{points_}"
                          hp="{hp_}"/>
      <ReadPoints points="{points_}"/>
      <ReadHp hp="{hp_}"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ReadHp">
      <input_port name="hp"
                  type="int"/>
    </Action>
    <Action ID="ReadPoints">
      <input_port name="points"
                  type="Position2D"/>
    </Action>
    <Action ID="SetTemplateBlackboard"
            editable="true">
      <output_port name="points"
                   type="Position2D"/>
      <output_port name="hp"
                   type="int"/>
    </Action>
  </TreeNodesModel>

</root>
