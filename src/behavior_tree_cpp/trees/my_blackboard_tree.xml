<?xml version="1.0" encoding="UTF-8"?>

<root BTCPP_format="4">

  <TreeNodesModel>
    <Action ID="SaySomething">
      <input_port name="message" type="std::string"/>
    </Action>
    <Action ID="ThinkWhatToSay">
      <output_port name="text" type="std::string"/>
    </Action>
  </TreeNodesModel>

  <BehaviorTree ID="MainTree">
    <Sequence name="root_sequence">
      <Action ID="SaySomething" name="say_hello" message="hello"/>
      <Action ID="ThinkWhatToSay" name="think_answer" text="{text}"/>
      <Action ID="SaySomething" name="say_answer" message="{text}"/>
    </Sequence>
  </BehaviorTree>

</root>
