<?xml version="1.0"?>

<!--ros2 launch urdf_tutorial display.launch.py model:=/home/yinkangan/Desktop/ros_practise/src/my_robot.urdf-->

<robot name="my_robot">

  <material name="green">
    <color rgba="0 0.5 0 0.95" />
  </material>

  <material name="red">
    <color rgba="0 0 0.5 0.8" />
  </material>

  <material name="blue">
    <color rgba="0 0 1 0.8" />
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 0.8" />
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0" />
      <material name="green" />
    </visual>
  </link>

  <link name="second_link">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.2" />
      </geometry>
      <origin xyz="0 0 0.1" rpy = "0 0 0" />
      <material name = "blue" />
    </visual>
  </link>

  <joint name = "base_second_joint" type = "continuous">
    <parent link = "base_link" />
    <child link = "second_link" />
    <origin xyz = "0 0 0.2" rpy = "0 0 0" />
    <axis xyz = "0 0 1" />
    <!-- <limit lower = "-1.57" upper = "1.57" velocity = "100" effort = "1000" /> -->
  </joint>

  <link name="third_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <material name="gray" />
    </visual>
  </link>

  <joint name = "second_third_joint" type = "fixed">
    <parent link = "second_link" />
    <child link = "third_link" />
    <origin xyz = "0 0 0.2" rpy = "0 0 1" />
  </joint>

  <link name = "4">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.2" />
      </geometry>
    </visual>
    <origin xyz = "0 0 0" rpy = "0 0 1"/>
    <material name="red" />
  </link>

  <joint name = "base_4_joint" type = "prismatic">
    <parent link = "base_link"/>
    <child link = "4"/>
    <origin xyz = "0 0 0.3" rpy = "0 0 0"/>
    <axis xyz = "1 0 0"/>
    <limit lower = "-0.2" upper = "0.2" velocity = "100" effort = "100"/>
  </joint>

</robot>
