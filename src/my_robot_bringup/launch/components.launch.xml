<launch>
  <!--启动容器-->
  <node pkg="rclcpp_components" exec="component_container_mt" name="my_container"/>
  <!--在终端运行命令-->
  <executable cmd="ros2 component load /my_container components_cpp 
      my_namespace::PublishNumber -r __node:=number_publisher_1"
      output="screen"/>
  <executable cmd="ros2 component load /my_container components_cpp 
      my_namespace::PublishNumber -r __node:=number_publisher_2"
      output="screen"/>
</launch>

<!--
1.component_container：内部使用 SingleThreadedExecutor
2.component_container_mt：内部使用 MultiThreadedExecutor
3.component_container_isolated：为每个加载的组件创建一个独立的单线程执行器
    相当于每个组件在自己的线程中运行，互不干扰。适合需要完全隔离但又是单线程逻辑的组件
-->